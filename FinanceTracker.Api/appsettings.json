{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/financetracker-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "super-secret-key-change-in-production-min-32-chars!!",
    "Issuer": "FinanceTracker",
    "Audience": "FinanceTracker",
    "ExpiresInHours": 24
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "finance-tracker"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=financetracker;Username=postgres;Password=postgres;SSL Mode=Disable"
  }
}
